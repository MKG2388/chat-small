# App hostname (used in Traefik routing)
APP_HOSTNAME=

# Generate a strong secret: openssl rand -base64 32
OIDC_CLIENT_SECRET=

# Keycloak
OIDC_AUTHORITY=
OIDC_REDIRECT_URI=

# SPARQL endpoint
SPARQL_ENDPOINT=

# LLM API defaults (pre-filled in the UI, users can override)
DEFAULT_API_BASE_URL=https://api.openai.com/v1
DEFAULT_API_MODEL=gpt-4o-mini
