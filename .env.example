# OIDC / Keycloak (leave OIDC_AUTHORITY empty to disable authentication)
OIDC_AUTHORITY=http://localhost:8080/realms/codw
OIDC_CLIENT_ID=codw-app
OIDC_CLIENT_SECRET=change-me-in-production
OIDC_REDIRECT_URI=http://localhost:8501

# SPARQL endpoint
SPARQL_ENDPOINT=

# LLM API defaults (pre-filled in the UI, users can override)
DEFAULT_API_BASE_URL=https://api.openai.com/v1
DEFAULT_API_MODEL=gpt-4o-mini
